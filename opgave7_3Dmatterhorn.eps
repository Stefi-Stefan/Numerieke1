  /Decode [0 1 0 1 0 1]
  /DataSource Data
  /Height 262
  /ImageMatrix [480 0 0 262 0 0]
  /Width 480
  /BitsPerComponent 8
>> image
} stopped {handleerror} if
  RawData flushfile
} exec
